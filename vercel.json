{
    "rewrites": [
          { "source": "/blog/:slug", "destination": "/api/blog/:slug" },
          { "source": "/blog", "destination": "/api/blog-listing" }
    ],
    "headers": [
          {
                  "source": "/api/(.*)",
                  "headers": [
                            { "key": "X-Content-Type-Options", "value": "nosniff" },
                            { "key": "X-Frame-Options", "value": "DENY" }
                  ]
          }
    ]
}
